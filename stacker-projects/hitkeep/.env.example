# Copy this file to .env and fill in before first deploy:
#   cp .env.example .env && ./scripts/generate-secrets.sh

# Public config
HITKEEP_PUBLIC_URL=http://localhost:8080
HITKEEP_BACKUP_INTERVAL=60
HITKEEP_BACKUP_RETENTION=24
HITKEEP_MCP_MAX_RANGE_DAYS=366

# Secrets to set manually
HITKEEP_AI_API_KEY=
HITKEEP_GOOGLE_SEARCH_CONSOLE_CLIENT_ID=
HITKEEP_GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=
HITKEEP_GOOGLE_SEARCH_CONSOLE_REDIRECT_URL=
HITKEEP_MAIL_HOST=
HITKEEP_MAIL_PORT=587
HITKEEP_MAIL_USERNAME=
HITKEEP_MAIL_PASSWORD=
HITKEEP_MAIL_FROM_ADDRESS=hitkeep@localhost
HITKEEP_MAIL_FROM_NAME=HitKeep

# Secrets generated by scripts/generate-secrets.sh
HITKEEP_JWT_SECRET=
