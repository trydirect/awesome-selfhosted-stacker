# Stacker configuration — generated by `stacker init --from-github floci-io/floci`
# Docs: https://docs.try.direct/stacker

name: floci
version: 0.1.0
deploy:
  target: local
ai:
  enabled: true
  provider: ollama
  timeout: 0
app:
  type: custom
  path: .
monitoring:
  status_panel: false
proxy:
  type: none
  auto_detect: false
