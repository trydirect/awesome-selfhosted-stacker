# Copy this file to .env and fill in before first deploy:
#   cp .env.example .env && ./scripts/generate-secrets.sh

# Public config
COMMON_DOMAIN=example.com

# Cloud config
HETZNER_REGION=fsn1
HETZNER_SERVER_TYPE=cpx22

# Secrets (generated by scripts/generate-secrets.sh)
DB_PASSWORD=
ADMIN_PASSWORD=
SECRET_KEY=
JWT_SECRET=
SMTP_PASSWORD=
SMTP_USER=

# App config
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder

# SMTP relay
SMTP_RELAY_HOST=
SMTP_RELAY_PORT=
SMTP_RELAY_USER=
SMTP_RELAY_PASSWORD=
SMTP_RELAY_ALIASES=

# Contact pipe
CONTACT_PIPE_URL=
CONTACT_PIPE_TOKEN=
CONTACT_TO_EMAIL=
