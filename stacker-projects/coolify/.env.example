# Copy to .env and generate secrets before first deploy:
#   cp .env.example .env && ./scripts/generate-secrets.sh

# Cloud config
HETZNER_REGION=fsn1
HETZNER_SERVER_TYPE=cpx22
STACKER_SSH_KEY=~/.ssh/id_ed25519

# Public config
APP_NAME=Coolify
APP_ENV=production

# Secrets (generated by scripts/generate-secrets.sh)
APP_KEY=
DB_PASSWORD=
REDIS_PASSWORD=
PUSHER_APP_SECRET=
