# Copy this file to .env and fill in before first deploy:
#   cp .env.example .env && ./scripts/generate-secrets.sh

# Twilio credentials are required for registration/login in the upstream Docker setup.

# Public config
BASE_DOMAIN=socio.localtest.me
HTTP_PORT=80
HTTPS_PORT=443
SQL_DB_NAME=scbsql
SQL_DB_USER=scbadmin
MONGO_DB_NAME=socioboard
MONGO_USER=socioboard
MAIL_HANDLER=smtp
SENDGRID_FROM_MAIL=admin@example.com
SENDGRID_CC_ADDR=
SOCIOBOARD_TWITTER_HANDLER=socioboard
AMEMBER_ENABLED=false
AMEMBER_DOMAIN=
ADMIN_PANEL_ENABLED=true
ADMIN_EMAIL=admin@scb.example
ADMIN_SESSION_NAME=sb_admin
API_SESSION_NAME=sb_api

# Secrets to set manually
TWILIO_ACC_SID=
TWILIO_AUTH_KEY=
TWILIO_SERVICE_ID=
