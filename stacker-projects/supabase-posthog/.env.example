# Copy this to .env and fill in secrets (or run ./scripts/generate-secrets.sh)
# Secrets will be auto-generated; non-secrets keep these values as defaults.

# --- Non-secret configuration (keep as-is) ---
POSTGRES_DB=postgres
POSTGRES_PORT=5432
SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:3000
DASHBOARD_USERNAME=supabase
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_SENDER_NAME=fake_sender
REGION=stub

# --- Supabase secrets ---
POSTGRES_PASSWORD=
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=
SECRET_KEY_BASE=
PG_META_CRYPTO_KEY=
DASHBOARD_PASSWORD=
SMTP_PASS=

# --- PostHog configuration ---
POSTHOG_SITE_URL=http://localhost:8001
POSTHOG_DB_PASSWORD=
POSTHOG_SECRET_KEY=
