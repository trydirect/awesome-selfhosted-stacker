# Copy this file to .env and fill in before first deploy:
#   cp .env.example .env && ./scripts/generate-secrets.sh

# Public config
COMMON_DOMAIN=example.com

# Cloud config
HETZNER_REGION=fsn1
HETZNER_SERVER_TYPE=cpx22

# Secrets (generated by scripts/generate-secrets.sh)
DB_PASSWORD=
ADMIN_PASSWORD=
SECRET_KEY=
JWT_SECRET=
SMTP_PASSWORD=
SMTP_USER=

# ComfyUI config
CLI_ARGS=""
PRELOAD_MODELS="[]"
